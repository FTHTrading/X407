# ============================================================
# .env.example  —  Safe to commit. Shows required env vars.
# Copy to .env.registry and fill in real values.
# ============================================================

# ── OpenSea API ────────────────────────────────────────────
# Get key: https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=your_opensea_api_key_here

# ── Operator wallet (public addresses — no keys here) ──────
OPERATOR_WALLET=0x0000000000000000000000000000000000000000
OPERATOR_ENS=your.eth

# ── WalletConnect (for wallet UI) ──────────────────────────
# Get project ID: https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ── Hardhat deploy (contracts package only) ────────────────
# All keys gitignored — store in packages/unyKorn-contracts/.env
# PRIVATE_KEY=0x...   (primary signer / deployer)
# PRIVATE_KEY_2=0x... (secondary signer)
# PRIVATE_KEY_3=0x... (tertiary signer)
POLYGON_RPC=https://polygon-rpc.com
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
BASE_RPC=https://mainnet.base.org

# ── UnyKorn L1 wallet + x402 demo ──────────────────────────
VITE_UNYKORN_RPC_URL=https://rpc.l1.unykorn.org
VITE_UNYKORN_CHAIN_ID=7331
VITE_UNYKORN_EXPLORER_URL=https://explorer.unykorn.org
VITE_UNYKORN_TREASURY_ADDRESS=uny1_DEMO_TREASURY
UNYKORN_RPC_URL=https://rpc.l1.unykorn.org
UNYKORN_CHAIN_ID=7331
UNYKORN_EXPLORER_URL=https://explorer.unykorn.org
UNYKORN_TREASURY_ADDRESS=uny1_DEMO_TREASURY
UNYKORN_CONFIRMATIONS=1

# ── x402 facilitator operator auth ─────────────────────────
# Optional but recommended for staging/production. When set,
# all facilitator /admin/* routes require one of:
# - Authorization: Bearer <token>
# - X-Admin-Token: <token>
ADMIN_API_TOKEN=replace_with_long_random_operator_token
