{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Inventory: Scan repo",
      "type": "shell",
      "command": "node scripts/inventory.mjs",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Hardhat: Compile",
      "type": "shell",
      "command": "npm run compile",
      "options": { "cwd": "${workspaceFolder}/packages/unyKorn-contracts" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Hardhat: Test",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}/packages/unyKorn-contracts" },
      "group": "test",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Hardhat: Deploy (local)",
      "type": "shell",
      "command": "npx hardhat run scripts/deploy.ts --network localhost",
      "options": { "cwd": "${workspaceFolder}/packages/unyKorn-contracts" },
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Hardhat: Node (local fork)",
      "type": "shell",
      "command": "npx hardhat node",
      "options": { "cwd": "${workspaceFolder}/packages/unyKorn-contracts" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Wallet UI: Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/packages/unyKorn-wallet" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Wallet UI: Build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/packages/unyKorn-wallet" },
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },

    // ── AWS Infrastructure ───────────────────────────────
    {
      "label": "AWS: Setup Tools",
      "type": "shell",
      "command": "powershell.exe -ExecutionPolicy Bypass -File aws/scripts/setup-tools.ps1",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "AWS: Deploy (devnet)",
      "type": "shell",
      "command": "powershell.exe -ExecutionPolicy Bypass -File aws/scripts/deploy.ps1 -Environment devnet",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "AWS: Deploy (staging)",
      "type": "shell",
      "command": "powershell.exe -ExecutionPolicy Bypass -File aws/scripts/deploy.ps1 -Environment staging",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "AWS: Teardown (devnet)",
      "type": "shell",
      "command": "powershell.exe -ExecutionPolicy Bypass -File aws/scripts/teardown.ps1 -Environment devnet",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "AWS: Terraform Plan",
      "type": "shell",
      "command": "terraform plan -var-file=environments/devnet.tfvars",
      "options": { "cwd": "${workspaceFolder}/aws/terraform" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "AWS: Terraform Init",
      "type": "shell",
      "command": "terraform init -upgrade",
      "options": { "cwd": "${workspaceFolder}/aws/terraform" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
