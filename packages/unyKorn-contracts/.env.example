# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# accounts[0] — primary deployer / owner
PRIVATE_KEY=
# accounts[1] — secondary signer (e.g. GlacierMint operator)
PRIVATE_KEY_2=
# accounts[2] — tertiary signer (e.g. vault controller / treasury)
PRIVATE_KEY_3=

AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
POLYGON_RPC=https://polygon-rpc.com
SNOWTRACE_API_KEY=
POLYGONSCAN_API_KEY=
REPORT_GAS=false
