{
  "name": "unykorn-contracts",
  "version": "0.1.0",
  "description": "UnyKorn EVM smart contracts — Hardhat project",
  "private": true,
  "scripts": {
    "compile":          "hardhat compile",
    "test":             "hardhat test",
    "deploy:local":              "hardhat run scripts/deploy.ts --network localhost",
    "deploy:avalanche":          "hardhat run scripts/deploy.ts --network avalanche",
    "deploy:base":               "hardhat run scripts/deploy.ts --network base",
    "deploy:polygon":            "hardhat run scripts/deploy.ts --network polygon",
    "deploy:all:local":          "hardhat run scripts/deployAll.ts --network localhost",
    "deploy:all:avalanche":      "hardhat run scripts/deployAll.ts --network avalanche",
    "deploy:all:base":           "hardhat run scripts/deployAll.ts --network base",
    "deploy:registry:local":     "hardhat run scripts/deployRegistry.ts --network localhost",
    "deploy:registry:avalanche": "hardhat run scripts/deployRegistry.ts --network avalanche",
    "deploy:registry:base":      "hardhat run scripts/deployRegistry.ts --network base",
    "verify:avalanche":     "hardhat run scripts/verify.ts --network avalanche",
    "verify:base":          "hardhat run scripts/verify.ts --network base",
    "verify:polygon":       "hardhat run scripts/verify.ts --network polygon",
    "balance":              "hardhat run scripts/checkBalance.ts --network avalanche",
    "balance:base":         "hardhat run scripts/checkBalance.ts --network base",
    "balances":             "hardhat run scripts/checkBalances.ts --network avalanche",
    "balances:base":        "hardhat run scripts/checkBalances.ts --network base",
    "balance:polygon":      "hardhat run scripts/checkBalance.ts --network polygon",
    "balances:polygon":     "hardhat run scripts/checkBalances.ts --network polygon",
    "node":                 "hardhat node",
    "typechain":            "hardhat typechain",
    "lint":                 "solhint 'contracts/**/*.sol'",
    "lp:deploy:avalanche":   "hardhat run scripts/deployLPManager.ts --network avalanche",
    "lp:deploy:local":       "hardhat run scripts/deployLPManager.ts --network localhost",
    "lp:check":              "hardhat run scripts/checkLP.ts --network avalanche",
    "lp:add":                "hardhat run scripts/addLiquidity.ts --network avalanche",
    "lp:add:dry":            "DRY_RUN=true hardhat run scripts/addLiquidity.ts --network avalanche",
    "lp:remove":             "hardhat run scripts/removeLiquidity.ts --network avalanche",
    "lp:remove:dry":         "DRY_RUN=true hardhat run scripts/removeLiquidity.ts --network avalanche",
    "lp:fees":               "hardhat run scripts/collectFees.ts --network avalanche",
    "lp:fees:dry":           "DRY_RUN=true hardhat run scripts/collectFees.ts --network avalanche",
    "lp:deepen":             "hardhat run scripts/deepenPools.ts --network avalanche",
    "lp:deepen:dry":         "DRY_RUN=true hardhat run scripts/deepenPools.ts --network avalanche",
    "treasury":              "hardhat run scripts/treasury.ts --network avalanche",
    "swap:usdc":             "POOL=usdc hardhat run scripts/swapTokens.ts --network avalanche",
    "swap:avax":             "POOL=wavax hardhat run scripts/swapTokens.ts --network avalanche"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.3",
    "dotenv": "^16.4.5",
    "solhint": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
