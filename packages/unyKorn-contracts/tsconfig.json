{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict":          true,
    "skipLibCheck":    true,
    "resolveJsonModule": true,
    "outDir":          "dist",
    "rootDir":         ".",
    "types":           ["hardhat/types", "mocha", "node"]
  },
  "include": ["hardhat.config.ts", "scripts/**/*.ts", "test/**/*.ts", "typechain-types/**/*.ts"],
  "exclude": ["node_modules", "artifacts", "cache", "dist"]
}
