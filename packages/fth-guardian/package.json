{
  "name": "fth-guardian",
  "version": "1.0.0",
  "private": true,
  "description": "FTH Guardian — daemon army for UnyKorn L1 + x402 infrastructure: monitoring, security, auto-healing, revenue generation, and self-upgrade",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "start": "node --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.8.4",
    "@fastify/cors": "^11.2.0",
    "pg": "^8.12.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0"
  }
}
