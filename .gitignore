# ── Secrets (never commit) ──────────────────────────────────────────────────
.env
.env.*
!.env.example
**/secrets/**
**/*.key
**/*.pem
**/*mnemonic*
**/*seed*
**/*.keystore
**/*.p12
**/*.pfx

# ── Node ────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── Build artefacts ─────────────────────────────────────────────────────────
dist/
build/
out/
.next/
artifacts/
cache/
typechain-types/
exports/

# ── OS noise ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ──────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo

# ── Coverage / test artefacts ────────────────────────────────────────────────
coverage/
lcov.info

# ── LP safety markers ───────────────────────────────────────────────────────
.lp-runs/

# ── Rust ────────────────────────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock
cargo_*.txt

# ── Docker / CI temp ────────────────────────────────────────────────────────
docker_build.txt
*.log
!docs/**/*.log

# ── SSM / temp output ───────────────────────────────────────────────────────
*.tmp
ssm_*.txt
.tmp-ssm-*

# ── Wrangler temp / Terraform cache ─────────────────────────────────────────
.wrangler/
**/.terraform/
**/.terraform-provider-cache/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
